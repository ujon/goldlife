# PostgreSQL persistence for users, profiles, recommendation sessions, cards, clicks, feedback.
# Tables are created under the `sai` schema.
# For Supabase/Vercel, prefer the transaction pooler URL and include sslmode when copying manually.
# Example: postgresql://postgres.<project-ref>:<password>@aws-...pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgres://sai:sai@127.0.0.1:5432/sai

# Required in production. Generate with: openssl rand -base64 48
JWT_SECRET=

# OpenAI recommendation orchestration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# API Fuse: restaurants, weather, routes
API_FUSE_API_KEY=

# Myrealtrip: activities, flights, stays
MYREALTRIP_API_KEY=

# tobl.ai / Cocoun MCP council
TOBL_API_KEY=
TOBL_MCP_URL=

# Optional / not just API-key issuance
#
# LG U+ / EXAONE model runtime
EXAONE_API_KEY=
EXAONE_BASE_URL=https://api.friendli.ai/serverless/v1
EXAONE_MODEL=LGAI-EXAONE/K-EXAONE-236B-A23B

# Supertone TTS. Ariel voice uses the low-latency sona_speech_2_flash model.
SUPERTONE_API_KEY=
SUPERTONE_BASE_URL=https://supertoneapi.com
SUPERTONE_MODEL=sona_speech_2_flash
SUPERTONE_VOICE_ID=7c56c6a6471a12816604f0
SUPERTONE_OUTPUT_FORMAT=mp3

# Development-only automatic login. Ignored in production builds.
DEV_AUTO_LOGIN=false
DEV_AUTO_LOGIN_EMAIL=codex-local@example.com
DEV_AUTO_LOGIN_PASSWORD=codex-local-password

# Swing mobility helper API
SWING_API_KEY=
SWING_BASE_URL=https://stage.playground.endpoint.swingmobility.dev

# Public APIs
GENRANK_BASE_URL=https://www.genrank.com
DATA_GO_KR_SERVICE_KEY=
